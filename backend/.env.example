# Core
SECRET_KEY=your-secret-key-here
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Database
DB_NAME=blog
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Media storage (object storage). Leave USE_S3=false for local dev (media on
# local disk). In production set USE_S3=true and fill in the bucket details.
# Works with AWS S3, Cloudflare R2, Backblaze B2, etc.
USE_S3=false
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=
# Required for non-AWS providers (R2/B2/MinIO), e.g.
#   https://<accountid>.r2.cloudflarestorage.com
AWS_S3_ENDPOINT_URL=
# Public CDN/bucket domain that serves the files to browsers, e.g.
#   cdn.example.com  (so image URLs are https://cdn.example.com/media/...)
AWS_S3_CUSTOM_DOMAIN=
AWS_LOCATION=media

# Production security (only applied when DEBUG=false; assumes HTTPS via proxy)
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
