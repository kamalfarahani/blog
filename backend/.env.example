# Core
SECRET_KEY=your-secret-key-here
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Database
DB_NAME=blog
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Media storage (object storage). Leave USE_S3=false for local dev (media on
# local disk). In production set USE_S3=true and fill in the bucket details.
# Works with AWS S3, Cloudflare R2, Backblaze B2, etc.
USE_S3=false
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=
# Required for non-AWS providers (R2/B2/MinIO), e.g.
#   https://<accountid>.r2.cloudflarestorage.com
AWS_S3_ENDPOINT_URL=
# Private bucket (default): image URLs are presigned and expire. Set to false
# only for a public bucket (then AWS_S3_CUSTOM_DOMAIN / CDN applies).
AWS_QUERYSTRING_AUTH=true
# Lifetime of presigned image URLs, in seconds (default 1 hour).
AWS_QUERYSTRING_EXPIRE=3600
# Public CDN/bucket domain, e.g. cdn.example.com — only used when
# AWS_QUERYSTRING_AUTH=false (signed URLs must hit the bucket host directly).
AWS_S3_CUSTOM_DOMAIN=
AWS_LOCATION=media

# Default superuser, created idempotently via `manage.py ensure_superuser`.
# Leave unset to skip creation.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me

# Production security (only applied when DEBUG=false; assumes HTTPS via proxy)
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
