# Copy to .env (docker compose reads it automatically).
#
# Defaults below run the full stack locally with DEBUG=true, so media is
# stored in the `media` volume and served by Django. For a production-style
# run, set DEBUG=false and configure object storage (USE_S3=true + AWS_* vars,
# see backend/README.md) — with DEBUG=false Django will NOT serve media itself.

# Core
SECRET_KEY=dev-insecure-change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Database (host is overridden to `db` for the backend service in compose)
DB_NAME=blog
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Media object storage (production). Leave USE_S3=false for the local stack.
USE_S3=false
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_LOCATION=media

# Production security (applied only when DEBUG=false)
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
