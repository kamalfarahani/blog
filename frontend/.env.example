# Copy to .env for local development (loaded automatically by the dev server).

# Base URL of the Django REST API. Used server-side only (inside server
# functions), so the browser never talks to the API directly.
# Local dev:   http://localhost:8000
# Docker compose: http://backend:8000
API_URL=http://localhost:8000

# Port the node server listens on (production / `node .output/server/index.mjs`).
PORT=3000
